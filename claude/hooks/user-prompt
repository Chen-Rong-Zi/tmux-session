#!/bin/bash
# UserPromptSubmit / UserPromptExpansion hook
# Intercepts /fork, /branch, tmux-fork, tmux-new commands

INPUT=$(cat)

# Guard: jq must be installed
if ! command -v jq &>/dev/null; then
  echo '{"decision":"block","reason":"✗ jq is required but not installed (install: brew install jq or apt-get install jq)"}'
  exit 0
fi

COMMAND_NAME=$(echo "$INPUT" | jq -r '.command_name // ""')
PROMPT=$(echo "$INPUT" | jq -r '.prompt // ""')
SESSION_ID=$(echo "$INPUT" | jq -r '.session_id // ""')
ARGS=$(echo "$INPUT" | jq -r '.command_args // ""')

# Strip namespace prefix from command_name: "claude-tmux-session:tmux-fork" -> "tmux-fork"
CMD="${COMMAND_NAME#*:}"

# Fallback: match on prompt for UserPromptSubmit path
if [ -z "$CMD" ]; then
  case "$PROMPT" in
    "/tmux-fork"*|"/tmux-new"*)
      CMD="tmux-${PROMPT#/tmux-}"
      CMD="${CMD%% *}"
      ARGS="${PROMPT#/* }"
      ;;
    *) exit 0 ;;
  esac
fi

case "$CMD" in
  "fork"|"branch"|"tmux-fork")
    # Fork to side pane
    if [ -z "$TMUX" ]; then
      echo '{"decision":"block","reason":"✗ Not in tmux — cannot fork to side pane"}'
      exit 0
    fi
    if [ -z "$SESSION_ID" ]; then
      echo '{"decision":"block","reason":"✗ No session_id available — cannot fork"}'
      exit 0
    fi
    if [ -n "$ARGS" ]; then
      NEW_CMD="claude --resume $SESSION_ID --fork-session -p \"$ARGS\""
    else
      NEW_CMD="claude --resume $SESSION_ID --fork-session"
    fi
    if tmux split-window -d "$NEW_CMD" 2>/dev/null; then
      echo "{\"decision\":\"block\",\"reason\":\"✓ Forked to side pane${ARGS:+ with prompt}\"}"
    else
      echo '{"decision":"block","reason":"✗ Fork failed: could not create side pane"}'
    fi
    ;;
  "new"|"tmux-new")
    # New session in new window
    if [ -z "$TMUX" ]; then
      echo '{"decision":"block","reason":"✗ Not in tmux — cannot open new window"}'
      exit 0
    fi
    if [ -n "$ARGS" ]; then
      NEW_CMD="claude -p \"$ARGS\""
    else
      NEW_CMD="claude"
    fi
    if tmux new-window "$NEW_CMD" 2>/dev/null; then
      echo "{\"decision\":\"block\",\"reason\":\"✓ New session opened in new window${ARGS:+ with prompt}\"}"
    else
      echo '{"decision":"block","reason":"✗ Failed to open new window"}'
    fi
    ;;
  *)
    exit 0
    ;;
esac
