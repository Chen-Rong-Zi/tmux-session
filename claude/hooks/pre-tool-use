#!/bin/bash
# Claude tmux session plugin - PreToolUse hook
# Intercepts /clear to create a new tmux window

# Read the tool input from stdin
INPUT=$(cat)

# Check if this is a /clear command
if echo "$INPUT" | grep -q '"command".*"/clear"'; then
  # Create a new tmux window with Claude
  if tmux new-window "claude" 2>/dev/null; then
    tmux display-message -d 3000 "✓ New session opened in new window"
  else
    tmux display-message -d 3000 "✗ Failed to open new session"
  fi
  # Block the original /clear command
  echo '{"block": true}'
  exit 0
fi

# Not a /clear command, allow it
echo '{"block": false}'
exit 0
