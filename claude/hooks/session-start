#!/bin/bash
# Claude tmux session plugin - SessionStart hook
# Logs plugin activation, fork is handled by /fork skill

LOG="/tmp/claude-tmux-session.log"
log() { echo "[$(date +%s)] $1" >> "$LOG"; }

log "session-start: plugin loaded"

# Check if in tmux
if [ -n "$TMUX_PANE" ]; then
  log "session-start: running in tmux (pane $TMUX_PANE)"
else
  log "session-start: not in tmux"
fi

exit 0
