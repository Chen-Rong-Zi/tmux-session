#!/bin/bash
# Claude tmux session plugin - SessionStart hook
# Only logs plugin activation, does NOT auto-fork

LOG="/tmp/claude-tmux-session.log"
log() { echo "[$(date +%s)] $1" >> "$LOG"; }

log "session-start: plugin loaded, reason=${1:-unknown}"

if [ -n "$TMUX_PANE" ]; then
  log "running in tmux (pane $TMUX_PANE)"
else
  log "not in tmux"
fi

exit 0
